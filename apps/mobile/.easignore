# ─────────────────────────────────────────────────────────────────────────────
# .easignore — arquivos excluídos do upload para EAS Build
# Reduz o tamanho do pacote de ~190 MB para ~30-40 MB
# ─────────────────────────────────────────────────────────────────────────────

# Dependências — EAS instala no servidor
node_modules/

# Cache e builds locais
.expo/
dist/
build/

# Diretórios nativos locais — EAS roda expo prebuild do zero via app.config.ts
# Sem isso, EAS encontra android/ local desatualizado e pula o prebuild
android/
ios/

# Testes
__tests__/
**/*.test.ts
**/*.test.tsx
**/*.spec.ts
**/*.spec.tsx

# Docs e configs de desenvolvimento
*.md
.vscode/
.idea/
.claude/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS
.DS_Store
Thumbs.db
